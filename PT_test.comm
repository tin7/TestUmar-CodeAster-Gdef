# coding=utf-8
# ==========================================================================
# PT_test.comm  — Tubo de Presión CANDU (Zr-2.5Nb), CRNL-4003 Rev.1
# Code_Aster 17.4.0 (Docker simvia/code_aster:17.4.0)
#
# Condiciones: P=10 MPa, T=300 C, flux=1.5e17 n/m2/s, t=10000 h
# Sector 30deg (1/12 del tubo), malla en metros
# ==========================================================================

from run_aster.toolbox import make_shared

DEBUT(CODE="OUI")

# Compilar UMAT dentro del contenedor
make_shared("libUMAT4001.so", "UMAT4001.f90")

# -----------------------------------------------------------------------
# 1. MALLA
# -----------------------------------------------------------------------
mesh = LIRE_MAILLAGE(FORMAT='MED')

mesh = DEFI_GROUP(
    reuse=mesh,
    MAILLAGE=mesh,
    CREA_GROUP_NO=(
        _F(GROUP_MA='Face_sym2', NOM='ND_SYM2'),
        _F(GROUP_MA='Face_int',  NOM='ND_FINT'),
    ),
)

# -----------------------------------------------------------------------
# 2. MODELO
# -----------------------------------------------------------------------
model = AFFE_MODELE(
    MAILLAGE=mesh,
    AFFE=_F(TOUT='OUI', PHENOMENE='MECANIQUE', MODELISATION='3D'),
)

# -----------------------------------------------------------------------
# 3. MATERIAL — Zr-2.5Nb CRNL-4003 Rev.1
#
# PROPS layout (45 entradas):
#   1-9:   E_a, E_t, E_r, nu_at, nu_ar, nu_tr, G_at, G_ar, G_tr
#  10-14: K1, K2, K3, Q1, Q3           (thermal creep)
#  15-18: F1, G1, F2, G2               (Hill anisotropy)
#  19-23: Kc, Q4, K5, K41, K42         (irradiation creep)
#  24-27: Fb, Ff, Gb, Gf               (texture irr.creep)
#  28-33: Kg, Q6, K61, K62, Cg, Bg     (growth)
#  34-37: Ga_b, Ga_f, Gt_b, Gt_f       (texture growth)
#  38:    flux_SI [n/m2/s]
#  39:    time_factor (1.0)
#  40:    x_scale_m  (1.0)
#  41:    Ltube [m]
#  42:    AX (3=Z)
#  43:    x0 [m]
#  44:    T_offset [K]
#  45:    flag_creep (1=active)
# -----------------------------------------------------------------------
ZrPT = DEFI_MATERIAU(
    ELAS=_F(E=91400.0, NU=0.38, ALPHA=0.0),
    UMAT=_F(
        LISTE_COEF=(
            84700.0,  99400.0,  90000.0,           # E_a, E_t, E_r [MPa]
            0.40,     0.36,     0.38,              # nu_at, nu_ar, nu_tr
            33200.0,  30300.0,  34600.0,           # G_at, G_ar, G_tr [MPa]
            7.5e7,    1.7e6,    2.04e-3,           # K1, K2, K3
            25000.0,  10000.0,                     # Q1, Q3 [K]
            0.52,     0.51,                        # F1, G1 (Hill n=1)
            0.38,     0.75,                        # F2, G2 (Hill n=2)
            6.85e-20, 9900.0,   1.1e-7,            # Kc, Q4, K5
            1.18,     -0.06,                       # K41, K42
            0.39,     0.31,    0.184,    0.195,    # Fb, Ff, Gb, Gf
            1.33e-28, -3400.0,  0.917,   0.0275,  # Kg, Q6, K61, K62
            2.54e-55,  1.6e-29,                    # Cg, Bg
            -0.535,    1.032,  -0.502,   0.913,    # Ga_b, Ga_f, Gt_b, Gt_f
            1.5e17,                                # flux [n/m2/s]
            1.0,                                   # time factor
            1.0,                                   # x_scale_m
            6.164,                                 # Ltube [m]
            3.0,                                   # AX=3 (Z axis)
            0.0,                                   # x0
            273.15,                                # T_offset
            1.0,                                   # flag_creep
        )
    ),
)

# -----------------------------------------------------------------------
# 4. TEMPERATURA — Campo uniforme constante 300 C
# -----------------------------------------------------------------------
TEMP_CH = CREA_CHAMP(
    OPERATION='AFFE',
    TYPE_CHAM='NOEU_TEMP_R',
    MAILLAGE=mesh,
    AFFE=_F(TOUT='OUI', NOM_CMP='TEMP', VALE=300.0),
)

TEMP_FLD = CREA_RESU(
    OPERATION='AFFE',
    TYPE_RESU='EVOL_THER',
    NOM_CHAM='TEMP',
    AFFE=(
        _F(CHAM_GD=TEMP_CH, INST=0.0),
        _F(CHAM_GD=TEMP_CH, INST=10000.0),
    ),
)

fieldmat = AFFE_MATERIAU(
    MAILLAGE=mesh,
    AFFE=_F(TOUT='OUI', MATER=(ZrPT,)),
    AFFE_VARC=_F(
        TOUT='OUI',
        EVOL=TEMP_FLD,
        NOM_VARC='TEMP',
        NOM_CHAM='TEMP',
        VALE_REF=20.0,
    ),
)

# -----------------------------------------------------------------------
# 5. CONDITIONS AUX LIMITES
#
#   Face_bot  (Z=0):       DZ=0
#   Face_sym1 (theta=0):   DY=0  (plano XZ)
#   Face_sym2 (theta=30):  LIAISON_OBLIQUE u.n=0
#   Face_int:              presion interna 10 MPa
# -----------------------------------------------------------------------
BC = AFFE_CHAR_MECA(
    MODELE=model,
    DDL_IMPO=(
        _F(GROUP_MA='Face_bot',  DZ=0.0),
        _F(GROUP_MA='Face_sym1', DY=0.0),
    ),
)

BC_SYM2 = AFFE_CHAR_MECA(
    MODELE=model,
    LIAISON_OBLIQUE=_F(
        GROUP_NO='ND_SYM2',
        ANGL_NAUT=(120.0, 0.0, 0.0),
        DX=0.0,
    ),
)

PRES = AFFE_CHAR_MECA(
    MODELE=model,
    PRES_REP=_F(GROUP_MA='Face_int', PRES=10.0),
)

# Carga axial de end-cap: σ_z = P × R_i² / (R_o² − R_i²)
# R_i=51.65mm, R_o=55.70mm → ratio=6.137 → σ_z = 10×6.137 = 61.37 MPa
# PRES_REP < 0 = tracción (+Z)
ENDCAP = AFFE_CHAR_MECA(
    MODELE=model,
    PRES_REP=_F(GROUP_MA='Face_top', PRES=-61.37),
)

# -----------------------------------------------------------------------
# 6. LISTAS DE INSTANTES (horas)
# -----------------------------------------------------------------------
LIST_T = DEFI_LIST_REEL(
    DEBUT=0.0,
    INTERVALLE=(
        _F(JUSQU_A=100.0,   PAS=10.0),
        _F(JUSQU_A=500.0,   PAS=50.0),
        _F(JUSQU_A=2000.0,  PAS=100.0),
        _F(JUSQU_A=10000.0, PAS=500.0),
    ),
)

LIST_ARCH = DEFI_LIST_REEL(
    VALE=(0.0, 100.0, 500.0, 1000.0, 2000.0, 5000.0, 7000.0, 10000.0),
)

LINST = DEFI_LIST_INST(
    DEFI_LIST=_F(LIST_INST=LIST_T),
    ECHEC=_F(
        ACTION='DECOUPE',
        EVENEMENT='ERREUR',
        SUBD_PAS=4,
    ),
)

RAMP = DEFI_FONCTION(
    NOM_PARA='INST',
    VALE=(0.0, 0.0, 10.0, 1.0, 10000.0, 1.0),
)

# -----------------------------------------------------------------------
# 7. ETAT_INIT — pre-cargar coordenadas de Gauss en STATEV(8:10)
#    Code_Aster 17.4 NO puebla COORDS en la interfaz UMAT.
#    Las coordenadas se pasan via STATEV(NSTATV-2:NSTATV) = V8,V9,V10.
# -----------------------------------------------------------------------
GEOM_N = CREA_CHAMP(
    TYPE_CHAM='NOEU_GEOM_R',
    OPERATION='EXTR',
    NOM_CHAM='GEOMETRIE',
    MAILLAGE=mesh,
)

GEOM_GP = CREA_CHAMP(
    TYPE_CHAM='ELGA_GEOM_R',
    OPERATION='DISC',
    MODELE=model,
    CHAM_GD=GEOM_N,
)

f_X = FORMULE(VALE='X', NOM_PARA=('X', 'Y', 'Z'))
f_Y = FORMULE(VALE='Y', NOM_PARA=('X', 'Y', 'Z'))
f_Z = FORMULE(VALE='Z', NOM_PARA=('X', 'Y', 'Z'))

CH_F = CREA_CHAMP(
    TYPE_CHAM='ELGA_NEUT_F',
    OPERATION='AFFE',
    MODELE=model,
    PROL_ZERO='OUI',
    AFFE=_F(TOUT='OUI', NOM_CMP=('X1', 'X2', 'X3'),
            VALE_F=(f_X, f_Y, f_Z)),
)

CH_XYZ = CREA_CHAMP(
    TYPE_CHAM='ELGA_NEUT_R',
    OPERATION='EVAL',
    CHAM_F=CH_F,
    CHAM_PARA=GEOM_GP,
)

VINI = CREA_CHAMP(
    TYPE_CHAM='ELGA_VARI_R',
    OPERATION='ASSE',
    MODELE=model,
    PROL_ZERO='OUI',
    ASSE=(
        _F(TOUT='OUI', CHAM_GD=CH_XYZ,
           NOM_CMP='X1', NOM_CMP_RESU='V8'),
        _F(TOUT='OUI', CHAM_GD=CH_XYZ,
           NOM_CMP='X2', NOM_CMP_RESU='V9'),
        _F(TOUT='OUI', CHAM_GD=CH_XYZ,
           NOM_CMP='X3', NOM_CMP_RESU='V10'),
    ),
)

# -----------------------------------------------------------------------
# 8. CÁLCULO NO-LINEAL
# -----------------------------------------------------------------------
RESU = STAT_NON_LINE(
    MODELE=model,
    CHAM_MATER=fieldmat,
    EXCIT=(
        _F(CHARGE=PRES,    FONC_MULT=RAMP),
        _F(CHARGE=ENDCAP,  FONC_MULT=RAMP),
        _F(CHARGE=BC),
        _F(CHARGE=BC_SYM2),
    ),
    COMPORTEMENT=_F(
        RELATION='UMAT',
        NOM_ROUTINE='umat',
        LIBRAIRIE='libUMAT4001.so',
        NB_VARI=10,
        TOUT='OUI',
    ),
    ETAT_INIT=_F(VARI=VINI),
    INCREMENT=_F(LIST_INST=LINST),
    NEWTON=_F(
        MATRICE='TANGENTE',
        PREDICTION='ELASTIQUE',
        REAC_ITER=1,
    ),
    CONVERGENCE=_F(
        ITER_GLOB_MAXI=30,
        RESI_GLOB_RELA=1.0e-5,
    ),
    ARCHIVAGE=_F(LIST_INST=LIST_ARCH),
    SOLVEUR=_F(METHODE='MUMPS'),
)

# -----------------------------------------------------------------------
# 9. POST-TRAITEMENT
# -----------------------------------------------------------------------
RESU = CALC_CHAMP(
    reuse=RESU,
    RESULTAT=RESU,
    DEFORMATION=('EPSI_NOEU',),
    CONTRAINTE=('SIGM_NOEU',),
    VARI_INTERNE=('VARI_NOEU',),
    TOUT_ORDRE='OUI',
)

IMPR_RESU(
    FORMAT='MED',
    UNITE=80,
    RESU=_F(
        RESULTAT=RESU,
        NOM_CHAM=('DEPL', 'EPSI_NOEU', 'SIGM_NOEU', 'SIEF_ELGA', 'VARI_NOEU'),
        TOUT_ORDRE='OUI',
    ),
)

TB_EPS = POST_RELEVE_T(
    ACTION=_F(
        INTITULE='eps_mean_Face_int',
        OPERATION='MOYENNE',
        RESULTAT=RESU,
        NOM_CHAM='EPSI_NOEU',
        NOM_CMP=('EPXX', 'EPYY', 'EPZZ'),
        GROUP_NO='ND_FINT',
        TOUT_ORDRE='OUI',
    ),
)

IMPR_TABLE(TABLE=TB_EPS, FORMAT='TABLEAU', SEPARATEUR=';')

FIN()
